{
  "coc.preferences.bracketEnterImprove": true,
  "prettier.singleQuote": true,
  "prettier.eslintIntegration": true,
  "prettier.disableLanguages": [""],
  "diagnostic.warningSign": " ",
  "diagnostic.errorSign": " ",
  "diagnostic.infoSign": " ",
  "diagnostic.hintSign": "ﯦ ",
  "diagnostic.showUnused": true,
  "diagnostic.virtualText": true,
  "explorer.quitOnOpen": true,
  "explorer.toggle": true,
  "explorer.width": 40,
  "explorer.git.showIgnored": true,
  "explorer.file.column.indent.indentLine": false,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.file.showHiddenFiles": true,
  "explorer.keyMappings.global": {
    "<cr>": ["expandable?", "expand", "open"],
    "v": "open:vsplit",
    "s": "open:split"
  },
  "snippets.userSnippetsDirectory": "~/.vim/snippets",
  "solargraph.diagnostics": true,
  "solargraph.formatting": true,
  "scss.lint.zeroUnits": "warning",
  "scss.lint.emptyRules": "warning",
  "scss.lint.duplicateProperties": "warning",
  "highlight.document.enable": false,
  "yank.highlight.duration": 300,
  "session.saveOnVimLeave": false,
  "session.directory": "~/.vim/sessions/",
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "wxss.validate": false,
  "diagnostic-languageserver.linters": {
    "scsslint": {
      "command": "scss-lint",
      "args": [
        "-f",
        "Default",
        "%file",
        "-c",
        "/Users/vasco.nunes/.scss-lint.yml"
      ],
      "formatLines": 1,
      "debounce": 100,
      "formatPattern": [
        "^[^:]+:(\\d+) (.*)$",
        {
          "line": 1,
          "message": 2
        }
      ],
      "sourceName": "scss-lint"
    }
  },
  "diagnostic-languageserver.formatters": {
    "scsslint": {
      "command": "scss-lint",
      "args": [
        "-f",
        "Default",
        "-o",
        "%file",
        "%file",
        "-c",
        "/Users/vasco.nunes/.scss-lint.yml"
      ],
      "rootPatterns": [],
      "isStdout": false,
      "isStderr": false,
      "doesWriteToFile": true
    }
  },
  "diagnostic-languageserver.filetypes": {
    "scss": "scsslint"
  },
  "diagnostic-languageserver.formatFiletypes": {
    "scss": "scsslint"
  }
}
