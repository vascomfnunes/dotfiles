################################
######## Account icloud ########
################################

IMAPAccount icloud
Host imap.mail.me.com
User vasco.m.nunes
PassCmd "security find-internet-password -s smtp.mail.me.com -w"
SSLType IMAPS
SSLVersions TLSv1.2
AuthMechs PLAIN
CertificateFile ~/.certificates.pem

# Remote storage

IMAPStore icloud-remote
Account icloud

# Local storage

MaildirStore icloud-local
Path ~/.mail/icloud/
Inbox ~/.mail/icloud/INBOX
Trash Trash

#
# Channels and Groups
# (so that we can rename local directories and flatten the hierarchy)

Channel icloud-folders
Master :icloud-remote:
Slave :icloud-local:
Patterns "INBOX" "Saved" "Drafts" "Archive" "Sent*" "Trash" "Junk"
Create Both
Expunge Both
SyncState *

Group icloud
Channel icloud-folders

