##### Completion

ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"

autoload -Uz compinit
zmodload zsh/datetime
zmodload zsh/stat

zcompdump="${ZDOTDIR}/.zcompdump"

if [[ ! -f "$zcompdump" ]] || (( EPOCHSECONDS - $(zstat +mtime -- "$zcompdump") > 86400 )); then
  compinit -d "$zcompdump"
else
  compinit -C -d "$zcompdump"
fi

if [[ ! -r "${zcompdump}.zwc" ]] || [[ "${zcompdump}.zwc" -ot "$zcompdump" ]]; then
  zcompile "${zcompdump}.zwc" "$zcompdump" 2>/dev/null || true
fi

unset zcompdump

zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
# Disable the built-in menu so fzf-tab can take over selection.
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'


##### Zinit plugins

# fzf-tab wants to load after compinit and before autosuggestions
# and syntax-highlighting, so it can wrap the completion widget first.
if [ -f "$ZINIT_HOME/zinit.zsh" ]; then
  source "$ZINIT_HOME/zinit.zsh"

  zinit ice wait lucid
  zinit light Aloxaf/fzf-tab
  zinit ice wait lucid
  zinit light zsh-users/zsh-autosuggestions
  zinit ice wait lucid
  zinit light zsh-users/zsh-syntax-highlighting
fi


