##### Helper functions

# pyradio forces TERM=xterm-256color under tmux and prints a warning;
# pre-set it to keep startup quiet. On exit, reset the terminal palette
# (OSC 104) since the theme redefines colors via init_color and
# tmux-256color has no `oc` capability to restore them.
pyradio() {
  TERM=xterm-256color command pyradio "$@"
  printf '\e]104\a'
}

dotupdate() {
  local profile="${1:-personal}"
  local dotfiles_dir="${${(%):-%x}:A:h:h}"

  if (( $# > 0 )); then shift; fi

  (cd "$dotfiles_dir" && git pull && ./install.sh "$profile" "$@")
}

# Cache expensive shell init commands and compile the generated zsh snippets.
source_command_cache() {
  local name="$1"
  local bin="$2"
  shift 2

  local bin_path
  bin_path="$(command -v "$bin")" || return

  local cache="${ZDOTDIR}/.${name}.zsh"

  if [[ ! -r "$cache" ]] || [[ "$cache" -ot "$bin_path" ]]; then
    local cache_tmp="${cache}.tmp.$$"
    if "$bin" "$@" >| "$cache_tmp"; then
      mv -f -- "$cache_tmp" "$cache"
    else
      rm -f -- "$cache_tmp"
    fi
  fi

  [[ -r "$cache" ]] || return

  if [[ ! -r "${cache}.zwc" ]] || [[ "${cache}.zwc" -ot "$cache" ]]; then
    zcompile "${cache}.zwc" "$cache" 2>/dev/null || true
  fi

  source "$cache"
}


