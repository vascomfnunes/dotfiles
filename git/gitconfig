[init]
	defaultBranch = main

[core]
	; editor = /Applications/RubyMine.app/Contents/MacOS/rubymine --wait
	editor = nvim
	autocrlf = input


##### Sync behavior

[pull]
	rebase = false

[push]
	default = current
	autoSetupRemote = true

[fetch]
	prune = true


##### Diffs and merges

[diff]
	colorMoved = default
	tool = codediff

[merge]
	conflictstyle = zdiff3
	tool = codediff

[difftool "codediff"]
	cmd = nvim \"$LOCAL\" \"$REMOTE\" -c \"lua vim.g.dotfiles_lazy.codediff()\" +\"CodeDiff file $LOCAL $REMOTE\"

[mergetool]
	keepBackup = false

[mergetool "codediff"]
	cmd = nvim \"$MERGED\" -c \"lua vim.g.dotfiles_lazy.codediff()\" -c \"CodeDiff merge \\\"$MERGED\\\"\"
	trustExitCode = true

[rerere]
	enabled = true

[branch]
	sort = -committerdate


##### Identity and signing

[user]
	name = Vasco Nunes
