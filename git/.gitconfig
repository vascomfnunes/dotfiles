# Install delta plugin from https://github.com/dandavison/delta
[user]
  name = Vasco Nunes
  email = contact@vasco.dev
  signingkey = A5EB75AD5B1D0E211E9FDE6121F9288BCED1AF2C
[includeIf "gitdir:~/repos/"]
    path = ~/repos/.gitconfig
[core]
  excludesfile = ~/.gitignore_global
  editor = nvim
  pager = delta
[interactive]
	diffFilter = delta --color-only
[web]
  browser = w3m
[github]
  user = vascomfnunes
[color]
  ui = true
[diff]
	colorMoved = default
[delta]
  syntax-theme = gruvbox-dark
	navigate = true
  line-numbers = true
  side-by-side = true
  minus-style = "#3c3836" bold ul "#ea6962"
  plus-style = "#3c3836" bold ul "#a9b665"
  line-numbers-minus-style = "#ea6962"
  line-numbers-plus-style = "#a9b665"
[merge]
	conflictstyle = diff3
	tool = vimdiff
[mergetool]
  path = nvim
[commit]
  template = ~/.gitmessage
  gpgsign = true
[tag]
  gpgsign = true
[init]
  defaultBranch = main
