##### Theme

# The generated theme follows the macOS appearance and is watched for live
# updates. A leading * enables PyRadio's theme file watcher.
theme = *catppuccin-auto


##### Remote control

# Used by the tmux status bar helper to read the current track title.
remote_control_server_ip = localhost
remote_control_server_port = 9998
remote_control_server_auto_start = True
